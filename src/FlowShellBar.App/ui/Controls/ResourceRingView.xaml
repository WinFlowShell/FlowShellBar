<UserControl
    x:Class="FlowShellBar.App.Ui.Controls.ResourceRingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FlowShellBar.App.Ui.Converters"
    x:Name="ControlRoot">

    <UserControl.Resources>
        <converters:PercentageToArcGeometryConverter x:Key="PercentageToArcGeometryConverter" />
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
        <Grid Width="20" Height="20">
            <Ellipse Width="20" Height="20" Stroke="{StaticResource ShellTrackBrush}" StrokeThickness="1.4" />
            <Path Data="{x:Bind ProgressValue, Mode=OneWay, Converter={StaticResource PercentageToArcGeometryConverter}, ConverterParameter=20}"
                Stroke="{x:Bind IndicatorBrush, Mode=OneWay}" StrokeThickness="1.4"
                StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
            <Viewbox Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="10" Height="10">
                    <Grid x:Name="MemoryIcon" Visibility="Collapsed">
                        <Rectangle Width="7" Height="4.6" RadiusX="0.8" RadiusY="0.8" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Stroke="{x:Bind IndicatorBrush, Mode=OneWay}" StrokeThickness="1" />
                        <Rectangle Width="3.8" Height="0.8" Margin="0,-1.2,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                        <Rectangle Width="3.8" Height="0.8" Margin="0,1.2,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                    </Grid>

                    <Grid x:Name="TemperatureIcon" Visibility="Collapsed">
                        <Rectangle Width="1.4" Height="4.7" RadiusX="0.7" RadiusY="0.7" Margin="0,0.8,0,0" HorizontalAlignment="Center" VerticalAlignment="Top"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                        <Ellipse Width="3.6" Height="3.6" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                    </Grid>

                    <Grid x:Name="CpuIcon" Visibility="Collapsed">
                        <Rectangle Width="1.4" Height="2.2" Margin="1.2,0,0,1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                        <Rectangle Width="1.4" Height="4.0" Margin="0,0,0,1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                        <Rectangle Width="1.4" Height="5.6" Margin="0,0,1.2,1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Fill="{x:Bind IndicatorBrush, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Viewbox>
        </Grid>

        <TextBlock Style="{StaticResource SmallTextStyle}" Foreground="{x:Bind IndicatorBrush, Mode=OneWay}" Text="{x:Bind ValueText, Mode=OneWay}" />
    </StackPanel>
</UserControl>
