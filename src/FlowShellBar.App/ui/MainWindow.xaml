<Window x:Class="FlowShellBar.App.Ui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:FlowShellBar.App.Ui.Controls"
    xmlns:converters="using:FlowShellBar.App.Ui.Converters"
    xmlns:imaging="using:Microsoft.UI.Xaml.Media.Imaging"
    mc:Ignorable="d"
    Title="FlowShellBar">
    <Grid x:Name="ShellRoot" Background="Transparent">
        <Grid.Resources>
            <converters:WorkspaceActiveToBrushConverter x:Key="WorkspaceActiveToBrushConverter" />
            <converters:WorkspaceForegroundConverter x:Key="WorkspaceForegroundConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <converters:PercentageToArcGeometryConverter x:Key="PercentageToArcGeometryConverter" />
            <converters:PanelToggleBackgroundConverter x:Key="PanelToggleBackgroundConverter" />
            <converters:PanelToggleBorderConverter x:Key="PanelToggleBorderConverter" />

            <MenuFlyout x:Key="LeftZoneFlyout">
                <MenuFlyoutItem Text="Open Launcher" Click="OnOpenLauncherFlyoutClick" />
                <MenuFlyoutItem Text="Toggle Overview" Click="OnToggleOverviewFlyoutClick" />
            </MenuFlyout>
            <MenuFlyout x:Key="WorkspaceFlyout">
                <MenuFlyoutItem Text="Toggle Overview" Click="OnToggleOverviewFlyoutClick" />
            </MenuFlyout>
            <MenuFlyout x:Key="StatusFlyout">
                <MenuFlyoutItem Text="Open Status Panel" Click="OnOpenStatusPanelFlyoutClick" />
            </MenuFlyout>
        </Grid.Resources>

        <Border Margin="10,4,10,4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Translation="0,0,18"
            Background="{StaticResource ShellSurfaceBrush}" BorderBrush="{StaticResource ShellBorderBrush}"
            BorderThickness="1" CornerRadius="17">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid Padding="6,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Background="Transparent"
                    ContextFlyout="{StaticResource LeftZoneFlyout}" Tapped="OnLeftZoneTapped"
                    PointerWheelChanged="OnLeftZonePointerWheelChanged">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border Width="30" Height="30" VerticalAlignment="Center"
                            Background="{Binding IsLeftPanelOpen, Converter={StaticResource PanelToggleBackgroundConverter}}"
                            BorderBrush="{Binding IsLeftPanelOpen, Converter={StaticResource PanelToggleBorderConverter}}"
                            BorderThickness="1" CornerRadius="15">
                            <Image Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                                <Image.Source><imaging:SvgImageSource UriSource="ms-appx:///Assets/Icons/ShellEntryStar.svg" /></Image.Source>
                            </Image>
                        </Border>
                        <StackPanel MinWidth="180" MaxWidth="320" VerticalAlignment="Center" Spacing="-4">
                            <TextBlock Style="{StaticResource MutedSmallTextStyle}" CharacterSpacing="80"
                                Text="{Binding ActiveContext.ActiveWindowAppName}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding ActiveContext.ActiveWindowTitle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    ContextFlyout="{StaticResource WorkspaceFlyout}" ColumnSpacing="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="248" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="248" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource BarGroupStyle}" HorizontalAlignment="Right">
                        <Grid VerticalAlignment="Center" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid x:Name="ResourcesAnchor" Grid.Column="0" Background="Transparent"
                                PointerEntered="OnResourcesAnchorPointerEntered" PointerExited="OnResourcesAnchorPointerExited"
                                Tapped="OnResourcesAnchorTapped">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <controls:ResourceRingView ProgressValue="{Binding Resources.Memory.ProgressValue}"
                                        IndicatorBrush="{Binding Resources.Memory.IndicatorBrush}"
                                        ValueText="{Binding Resources.Memory.ValueText}"
                                        IconKind="Memory" />
                                    <controls:ResourceRingView ProgressValue="{Binding Resources.Temperature.ProgressValue}"
                                        IndicatorBrush="{Binding Resources.Temperature.IndicatorBrush}"
                                        ValueText="{Binding Resources.Temperature.ValueText}"
                                        IconKind="Temperature" />
                                    <controls:ResourceRingView ProgressValue="{Binding Resources.Cpu.ProgressValue}"
                                        IndicatorBrush="{Binding Resources.Cpu.IndicatorBrush}"
                                        ValueText="{Binding Resources.Cpu.ValueText}"
                                        IconKind="Cpu" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Column="1" MinWidth="108" MaxWidth="132" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="18" Height="18" VerticalAlignment="Center">
                                    <Ellipse Width="18" Height="18" Stroke="{StaticResource ShellTrackBrush}" StrokeThickness="1.2" />
                                    <Path Data="M9,1.4 A7.6,7.6 0 1 1 3.4,3.4" Stroke="{StaticResource WeatherAccentBrush}" StrokeThickness="1.2"
                                        StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <TextBlock Style="{StaticResource SymbolGlyphStyle}" FontSize="9" Foreground="{StaticResource WeatherAccentBrush}" Text="♪" />
                                </Grid>
                                <TextBlock Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource PrimaryTextBrush}"
                                    Text="Here Without You • 3..." TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="WorkspaceAnchor" Grid.Column="1" Style="{StaticResource BarGroupStyle}" Margin="0"
                        Padding="4,0" Background="{StaticResource ShellGroupAccentBrush}"
                        PointerEntered="OnWorkspaceAnchorPointerEntered" PointerExited="OnWorkspaceAnchorPointerExited"
                        PointerWheelChanged="OnWorkspaceAnchorPointerWheelChanged" RightTapped="OnWorkspaceAnchorRightTapped" Tapped="OnWorkspaceAnchorTapped">
                        <ItemsControl ItemsSource="{Binding Workspaces}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="0" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="26" Height="26" Padding="0" Background="Transparent" BorderThickness="0"
                                        Command="{Binding DataContext.SwitchWorkspaceCommand, ElementName=ShellRoot}" CommandParameter="{Binding Id}">
                                        <Grid>
                                            <Border Width="26" Height="26" Background="{StaticResource WorkspaceOccupiedBrush}" CornerRadius="13"
                                                Opacity="{Binding IsOccupied, Converter={StaticResource BoolToOpacityConverter}}" />
                                            <Border Width="22" Height="22" Background="{Binding IsActive, Converter={StaticResource WorkspaceActiveToBrushConverter}}"
                                                CornerRadius="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="JetBrains Mono" FontSize="9"
                                                FontWeight="SemiBold" Foreground="{Binding IsActive, Converter={StaticResource WorkspaceForegroundConverter}}" Text="{Binding Id}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource BarGroupStyle}" HorizontalAlignment="Left">
                        <Grid VerticalAlignment="Center" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ClockAnchor" Grid.Column="0" Background="Transparent"
                                PointerEntered="OnClockAnchorPointerEntered" PointerExited="OnClockAnchorPointerExited" Tapped="OnClockAnchorTapped">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource PrimaryTextStyle}" FontSize="12" Text="{Binding Clock.CurrentTime}" />
                                    <TextBlock Style="{StaticResource DateTextStyle}" Text="·" />
                                    <TextBlock Style="{StaticResource DateTextStyle}" Text="{Binding Clock.CurrentDate}" />
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Border Style="{StaticResource UtilityCircleStyle}"><TextBlock Style="{StaticResource SymbolGlyphStyle}" Text="◫" /></Border>
                                <Border Style="{StaticResource UtilityCircleStyle}"><TextBlock Style="{StaticResource SymbolGlyphStyle}" Text="✎" /></Border>
                                <Border Style="{StaticResource UtilityCircleStyle}"><TextBlock Style="{StaticResource SymbolGlyphStyle}" Text="⌨" /></Border>
                                <Border Style="{StaticResource UtilityCircleStyle}"><TextBlock Style="{StaticResource SymbolGlyphStyle}" Text="◐" /></Border>
                            </StackPanel>
                            <Border Grid.Column="2" Height="22" Padding="7,0" VerticalAlignment="Center"
                                Background="{StaticResource UtilityButtonBrush}" BorderBrush="{StaticResource UtilityButtonBorderBrush}"
                                BorderThickness="1" CornerRadius="11">
                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <Grid Width="14" Height="8" VerticalAlignment="Center">
                                        <Border Width="12" Height="8" HorizontalAlignment="Left" BorderBrush="{StaticResource BatteryTrackBrush}" BorderThickness="1" CornerRadius="2" />
                                        <Rectangle Width="2" Height="4" Margin="0,0,-2,0" HorizontalAlignment="Right" Fill="{StaticResource BatteryTrackBrush}" />
                                        <Rectangle Width="7" Height="4" Margin="2,0,0,0" HorizontalAlignment="Left" Fill="{StaticResource BatteryFillBrush}" />
                                    </Grid>
                                    <TextBlock Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource PrimaryTextBrush}" Text="87" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="RightZone" Grid.Column="2" Background="Transparent" ContextFlyout="{StaticResource StatusFlyout}"
                    Tapped="OnRightZoneTapped" PointerWheelChanged="OnRightZonePointerWheelChanged">
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Style="{StaticResource BarGroupStyle}" Padding="8,0">
                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource WeatherAccentBrush}" Text="☁" />
                                <TextBlock Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource PrimaryTextBrush}" Text="26°C" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource BarGroupStyle}" Padding="7,0">
                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                <Ellipse Width="4" Height="4" Fill="{StaticResource RightStatusAccentBrush}" />
                                <Ellipse Width="4" Height="4" Fill="{StaticResource MutedTextBrush}" />
                                <Ellipse Width="4" Height="4" Stroke="{StaticResource MutedTextBrush}" StrokeThickness="1" />
                                <TextBlock Style="{StaticResource MutedSmallTextStyle}" Text="⌄" />
                            </StackPanel>
                        </Border>
                        <Border Height="28" Padding="10,0" VerticalAlignment="Center"
                            Background="{Binding IsRightPanelOpen, Converter={StaticResource PanelToggleBackgroundConverter}}"
                            BorderBrush="{Binding IsRightPanelOpen, Converter={StaticResource PanelToggleBorderConverter}}"
                            BorderThickness="1" CornerRadius="14">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource SmallTextStyle}" Foreground="{StaticResource PrimaryTextBrush}" Text="EN" />
                                <Ellipse Width="5" Height="5" Fill="{Binding Status.ConnectionStateForeground}" />
                                <Ellipse Width="5" Height="5" Fill="{StaticResource RightStatusAccentBrush}" Opacity="{Binding Status.IsAudioAvailable, Converter={StaticResource BoolToOpacityConverter}}" />
                                <Ellipse Width="5" Height="5" Fill="{StaticResource RightStatusAccentBrush}" Opacity="{Binding Status.HasNotifications, Converter={StaticResource BoolToOpacityConverter}}" />
                                <Rectangle Width="5" Height="5" RadiusX="1" RadiusY="1" Fill="{StaticResource RightStatusAccentBrush}" Opacity="{Binding Status.IsNetworkAvailable, Converter={StaticResource BoolToOpacityConverter}}" />
                                <Ellipse Width="5" Height="5" Stroke="{StaticResource RightStatusAccentBrush}" StrokeThickness="1" Opacity="0.75" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
